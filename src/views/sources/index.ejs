<%- include('../partials/header', { title: 'Websites' }) %>

<div class="mb-6 flex items-center justify-between flex-wrap gap-3">
  <div>
    <h1 class="text-2xl font-bold">Websites</h1>
    <p class="text-sm text-slate-500 mt-0.5"><%= sources.length %> website<%= sources.length !== 1 ? 's' : '' %> · refreshed daily at 6 am</p>
  </div>
  <div class="flex gap-2">
    <% if (scraping) { %>
      <span class="bg-yellow-50 border border-yellow-200 text-yellow-800 text-sm px-3 py-2 rounded font-medium">
        Refreshing in background…
      </span>
    <% } %>
    <form method="POST" action="/sources/scrape-all">
      <button type="submit"
        class="bg-slate-700 text-white px-3 py-2 rounded text-sm font-medium hover:bg-slate-800 transition">
        Refresh all now
      </button>
    </form>
    <a href="/sources/new"
       class="bg-blue-600 text-white px-4 py-2 rounded font-medium hover:bg-blue-700 text-sm transition">
      + Add website
    </a>
  </div>
</div>

<% if (sources.length === 0) { %>
  <div class="text-center py-16 text-slate-400">
    <p class="text-4xl mb-3">🔗</p>
    <p class="text-lg font-medium text-slate-600">No websites yet</p>
    <p class="mt-1 text-sm">Add a URL and the scraper will monitor it daily.</p>
  </div>
<% } else { %>

  <%
  const CATEGORY_ORDER = ['district','school','camp','preschool','afterschool','activity','community','tutoring','enrichment','other'];
  const grouped = {};
  sources.forEach(s => {
    if (!grouped[s.category]) grouped[s.category] = [];
    grouped[s.category].push(s);
  });
  %>

  <% CATEGORY_ORDER.forEach(cat => {
    if (!grouped[cat]) return;
  %>
    <div class="mb-6">
      <div class="mb-2">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 capitalize"><%= cat %></h2>
      </div>

      <div class="space-y-1.5">
      <% grouped[cat].forEach(s => {
        const isStale = s.last_scraped_at && (Date.now() - new Date(s.last_scraped_at).getTime()) > 8 * 24 * 3600000;
      %>
        <div class="bg-white rounded-lg border <%= s.last_scrape_status === 'error' ? 'border-red-200' : 'border-slate-200' %> p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-medium text-slate-900 truncate"><%= s.name %></span>
                <% if (!s.active) { %>
                  <span class="text-xs bg-slate-100 text-slate-400 px-1.5 py-0.5 rounded">paused</span>
                <% } %>
                <% if (s.last_scrape_status === 'success') { %>
                  <span class="text-xs bg-green-100 text-green-700 px-1.5 py-0.5 rounded">✓ OK</span>
                <% } else if (s.last_scrape_status === 'error') { %>
                  <span class="text-xs bg-red-100 text-red-600 px-1.5 py-0.5 rounded">✗ Error</span>
                <% } else { %>
                  <span class="text-xs bg-slate-100 text-slate-400 px-1.5 py-0.5 rounded">not refreshed</span>
                <% } %>
                <% if (isStale) { %>
                  <span class="text-xs bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded">stale 7d+</span>
                <% } %>
              </div>

              <a href="<%= s.url %>" target="_blank" rel="noopener"
                 class="text-xs text-slate-400 hover:text-blue-500 truncate block mt-0.5 max-w-sm"><%= s.url %></a>

              <div class="flex items-center gap-3 mt-1.5 text-xs text-slate-400 flex-wrap">
                <% if (s.last_scraped_at) { %>
                  <span>Last refreshed: <%= new Date(s.last_scraped_at).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
                <% } %>
                <% if (s.event_count > 0) { %>
                  <span><%= s.event_count %> event<%= s.event_count !== 1 ? 's' : '' %></span>
                <% } %>
                <% if (s.last_scrape_status === 'error' && s.last_scrape_message) { %>
                  <span class="text-red-500 truncate max-w-xs"><%= s.last_scrape_message %></span>
                <% } %>
              </div>
            </div>

            <div class="flex items-center gap-3 shrink-0">
              <button id="refresh-btn-<%= s.id %>"
                onclick="refreshOne(<%= s.id %>)"
                class="text-xs text-slate-500 hover:text-green-700 border border-slate-200 hover:border-green-300 px-2 py-1.5 rounded transition">
                Refresh
              </button>
              <a href="/sources/<%= s.id %>/edit"
                 class="text-sm text-blue-600 hover:text-blue-800">Edit</a>
            </div>
          </div>
        </div>
      <% }); %>
      </div>
    </div>
  <% }); %>

<% } %>

<script>
async function refreshOne(id) {
  const btn = document.getElementById('refresh-btn-' + id);
  btn.disabled = true;
  btn.textContent = '…';
  btn.classList.add('opacity-60');
  try {
    const r    = await fetch('/sources/' + id + '/scrape', { method: 'POST' });
    const data = await r.json();
    if (data.ok) {
      btn.textContent = '+' + data.eventsAdded;
      btn.classList.remove('opacity-60');
      btn.classList.add('text-green-700', 'border-green-300', 'bg-green-50');
    } else {
      btn.textContent = 'Error';
      btn.classList.remove('opacity-60');
      btn.classList.add('text-red-600', 'border-red-200', 'bg-red-50');
      console.error(data.error);
    }
  } catch(e) {
    btn.textContent = 'Error';
    btn.classList.remove('opacity-60');
    btn.classList.add('text-red-600');
  }
}
</script>

<%- include('../partials/footer') %>
