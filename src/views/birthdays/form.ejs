<%- include('../partials/header', { title: birthday ? 'Edit Birthday' : 'Add Birthday' }) %>

<div class="max-w-lg">
  <% if (birthday) { %>
    <div class="mb-4">
      <a href="/birthdays/<%= birthday.id %>" class="text-sm text-slate-500 hover:text-slate-700">← <%= birthday.child_name %>'s party</a>
    </div>
  <% } %>

  <h1 class="text-2xl font-bold mb-6"><%= birthday ? 'Edit Birthday' : 'Add Birthday' %></h1>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm"><%= error %></div>
  <% } %>

  <form method="POST" action="<%= birthday ? '/birthdays/' + birthday.id : '/birthdays' %>" class="bg-white rounded-lg shadow p-6 space-y-4">
    <% if (birthday) { %>
      <input type="hidden" name="_method" value="PUT" />
    <% } %>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Child's First Name</label>
      <input type="text" name="child_name" required value="<%= birthday ? birthday.child_name : '' %>"
        class="w-full border border-slate-300 rounded px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Child's Age (at party)</label>
      <input type="number" name="child_age" required min="0" max="18"
        value="<%= birthday ? birthday.child_age : '' %>"
        class="w-full border border-slate-300 rounded px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Party Date</label>
      <input type="date" name="party_date" required
        value="<%= birthday ? birthday.party_date : '' %>"
        class="w-full border border-slate-300 rounded px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Invite Received Date (optional)</label>
      <input type="date" name="invite_received_date"
        value="<%= birthday && birthday.invite_received_date ? birthday.invite_received_date : '' %>"
        class="w-full border border-slate-300 rounded px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700 mb-1">Notes (interests, themes — helps gift suggestions)</label>
      <textarea name="notes" rows="3" placeholder="e.g. loves dinosaurs, into LEGO, no candy"
        class="w-full border border-slate-300 rounded px-3 py-2 text-sm"><%= birthday && birthday.notes ? birthday.notes : '' %></textarea>
    </div>
    <div class="flex gap-3 pt-2">
      <button type="submit" class="bg-pink-600 text-white px-4 py-2 rounded font-medium hover:bg-pink-700 text-sm">
        <%= birthday ? 'Save Changes' : 'Add Birthday' %>
      </button>
      <a href="<%= birthday ? '/birthdays/' + birthday.id : '/birthdays' %>"
         class="text-slate-500 px-4 py-2 hover:text-slate-700 text-sm">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
