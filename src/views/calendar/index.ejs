<%- include('../partials/header', { title: monthLabel }) %>

<%
const DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const startOffset = firstDay.getDay(); // 0=Sun
const totalDays   = lastDay.getDate();
const totalCells  = Math.ceil((startOffset + totalDays) / 7) * 7;

function dotColor(type) {
  if (type === 'deadline')     return 'bg-orange-400';
  if (type === 'birthday')     return 'bg-pink-400';
  if (type === 'gift_reminder') return 'bg-pink-300';
  return 'bg-blue-400';
}
%>

<div class="mb-6 flex items-center justify-between gap-4 flex-wrap">
  <div class="flex items-center gap-3">
    <a href="/calendar?month=<%= prevMonth %>"
       class="p-2 rounded hover:bg-slate-100 text-slate-500 hover:text-slate-800 transition">
      &#8592;
    </a>
    <h1 class="text-xl font-bold w-44 text-center"><%= monthLabel %></h1>
    <a href="/calendar?month=<%= nextMonth %>"
       class="p-2 rounded hover:bg-slate-100 text-slate-500 hover:text-slate-800 transition">
      &#8594;
    </a>
    <a href="/calendar" class="text-xs text-slate-400 hover:text-slate-600 ml-1">Today</a>
  </div>
  <div class="flex items-center gap-3 flex-wrap">
    <div class="flex gap-2 text-xs text-slate-500">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>Event</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-orange-400 inline-block"></span>Deadline</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-pink-400 inline-block"></span>Birthday</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-pink-300 inline-block"></span>Gift reminder</span>
    </div>
    <div class="flex gap-2 text-sm">
      <% if (typeof webcalUrl !== 'undefined' && webcalUrl) { %>
      <a href="<%= webcalUrl %>"
         class="bg-white border border-slate-200 hover:border-blue-300 hover:text-blue-700 px-3 py-1.5 rounded font-medium text-slate-700 transition text-xs">
        Subscribe
      </a>
      <% } %>
      <a href="/calendar/export"
         class="bg-white border border-slate-200 hover:border-slate-300 px-3 py-1.5 rounded text-slate-600 hover:text-slate-900 transition text-xs">
        Download .ics
      </a>
    </div>
  </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
  <!-- Day-of-week header -->
  <div class="grid grid-cols-7 border-b border-slate-200">
    <% DOW.forEach(d => { %>
      <div class="py-2 text-center text-xs font-semibold text-slate-400 uppercase tracking-wide"><%= d %></div>
    <% }) %>
  </div>

  <!-- Calendar grid -->
  <div class="grid grid-cols-7" id="cal-grid">
    <% for (let cell = 0; cell < totalCells; cell++) {
      const dayNum = cell - startOffset + 1;
      const isThisMonth = dayNum >= 1 && dayNum <= totalDays;
      const dateStr = isThisMonth
        ? `${String(year).padStart(4,'0')}-${String(month).padStart(2,'0')}-${String(dayNum).padStart(2,'0')}`
        : null;
      const isToday = dateStr === todayStr;
      const entries = (dateStr && byDate[dateStr]) || [];
      const isLastRow = cell >= totalCells - 7;
    %>
      <div
        class="min-h-[80px] p-1.5 border-b border-r border-slate-100 last:border-r-0 relative
               <%= isLastRow ? 'border-b-0' : '' %>
               <%= !isThisMonth ? 'bg-slate-50' : '' %>
               <%= entries.length > 0 ? 'cursor-pointer hover:bg-blue-50 transition-colors' : '' %>"
        <% if (entries.length > 0) { %>
          onclick="selectDay('<%= dateStr %>')"
          data-date="<%= dateStr %>"
        <% } %>
      >
        <!-- Day number -->
        <% if (isThisMonth) { %>
          <span class="text-sm <%= isToday
            ? 'bg-blue-600 text-white w-6 h-6 rounded-full flex items-center justify-center font-bold'
            : 'text-slate-700' %> leading-none inline-flex items-center justify-center w-6 h-6">
            <%= dayNum %>
          </span>
        <% } %>

        <!-- Event dots -->
        <% if (entries.length > 0) { %>
          <div class="mt-1 flex flex-wrap gap-0.5">
            <% entries.slice(0, 4).forEach(function(entry) { %>
              <span class="w-1.5 h-1.5 rounded-full <%= dotColor(entry.type) %>"></span>
            <% }); %>
            <% if (entries.length > 4) { %>
              <span class="text-xs text-slate-400 leading-none">+<%= entries.length - 4 %></span>
            <% } %>
          </div>
          <!-- First entry label (if space) -->
          <% const label = entries[0].type === 'deadline' ? entries[0].ev.title
               : entries[0].type === 'event' ? entries[0].ev.title
               : entries[0].type === 'birthday' ? entries[0].b.child_name + "'s party"
               : '🎁 ' + entries[0].b.child_name; %>
          <p class="text-xs text-slate-600 mt-0.5 truncate leading-tight hidden sm:block"><%= label %></p>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<!-- Day detail panel (shown when a day is clicked) -->
<div id="day-panel" class="hidden mt-4 bg-white rounded-xl border border-slate-200 p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 id="day-panel-title" class="font-semibold text-slate-800"></h2>
    <button onclick="closePanel()" class="text-slate-400 hover:text-slate-600 text-lg leading-none">&times;</button>
  </div>
  <div id="day-panel-body" class="space-y-3"></div>
</div>

<script>
// All event data for JS access, keyed by date string
const byDate = <%- JSON.stringify(byDate) %>;

let selectedDate = null;

// Returns the best actionable URL: specific event URL first, source homepage as fallback.
function eventLink(ev) {
  return ev.url || ev.source_url || null;
}

function renderCTA(ev, isDeadline) {
  const link = eventLink(ev);
  if (link) {
    if (isDeadline) {
      return `<a href="${escHtml(link)}" target="_blank" rel="noopener noreferrer"
        class="inline-block mt-2 text-xs font-semibold bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg transition">
        Register →
      </a>`;
    }
    return `<a href="${escHtml(link)}" target="_blank" rel="noopener noreferrer"
      class="inline-block mt-2 text-xs font-medium border border-slate-300 hover:border-slate-400 text-slate-700 px-3 py-1.5 rounded-lg transition">
      Learn More →
    </a>`;
  }
  // No URL at all — show source attribution so user knows where to look
  return `<p class="text-xs text-slate-400 mt-2 italic">via ${escHtml(ev.source_name)}</p>`;
}

function escHtml(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function selectDay(dateStr) {
  selectedDate = dateStr;
  const entries = byDate[dateStr] || [];
  const panel = document.getElementById('day-panel');
  const title = document.getElementById('day-panel-title');
  const body  = document.getElementById('day-panel-body');

  const [y, m, d] = dateStr.split('-').map(Number);
  title.textContent = new Date(y, m - 1, d).toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' });

  body.innerHTML = entries.map(entry => {
    if (entry.type === 'deadline') {
      return `<div class="flex gap-3 p-3 bg-orange-50 rounded-lg">
        <span class="shrink-0 text-lg">⏰</span>
        <div class="min-w-0 flex-1">
          <p class="font-medium text-slate-900">${escHtml(entry.ev.title)}</p>
          ${entry.ev.description ? `<p class="text-sm text-slate-500 mt-0.5">${escHtml(entry.ev.description)}</p>` : ''}
          <div class="flex gap-2 mt-1.5 flex-wrap">
            <span class="text-xs bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded">deadline</span>
            <span class="text-xs bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded">${escHtml(entry.ev.category)}</span>
          </div>
          ${renderCTA(entry.ev, true)}
        </div>
      </div>`;
    }
    if (entry.type === 'event') {
      return `<div class="flex gap-3 p-3 bg-blue-50 rounded-lg">
        <span class="shrink-0 text-lg">📅</span>
        <div class="min-w-0 flex-1">
          <p class="font-medium text-slate-900">${escHtml(entry.ev.title)}</p>
          ${entry.ev.description ? `<p class="text-sm text-slate-500 mt-0.5">${escHtml(entry.ev.description)}</p>` : ''}
          <div class="flex gap-2 mt-1.5 flex-wrap">
            <span class="text-xs bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded">${escHtml(entry.ev.category)}</span>
          </div>
          ${renderCTA(entry.ev, false)}
        </div>
      </div>`;
    }
    if (entry.type === 'birthday') {
      return `<a href="/birthdays/${entry.b.id}" class="flex gap-3 p-3 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
        <span class="shrink-0 text-lg">🎂</span>
        <div>
          <p class="font-medium text-slate-900">${escHtml(entry.b.child_name)}'s party</p>
          <p class="text-sm text-slate-500">Age ${entry.b.child_age}</p>
        </div>
      </a>`;
    }
    if (entry.type === 'gift_reminder') {
      return `<a href="/birthdays/${entry.b.id}" class="flex gap-3 p-3 bg-pink-50 rounded-lg hover:bg-pink-100 transition-colors">
        <span class="shrink-0 text-lg">🎁</span>
        <div>
          <p class="font-medium text-slate-900">Gift reminder — ${escHtml(entry.b.child_name)}</p>
          <p class="text-sm text-slate-500">Party in 7 days — age ${entry.b.child_age}</p>
        </div>
      </a>`;
    }
    return '';
  }).join('');

  panel.classList.remove('hidden');

  document.querySelectorAll('[data-date]').forEach(el => el.classList.remove('ring-2','ring-blue-400','ring-inset'));
  const cell = document.querySelector(`[data-date="${dateStr}"]`);
  if (cell) cell.classList.add('ring-2','ring-blue-400','ring-inset');

  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function closePanel() {
  document.getElementById('day-panel').classList.add('hidden');
  document.querySelectorAll('[data-date]').forEach(el => el.classList.remove('ring-2','ring-blue-400','ring-inset'));
  selectedDate = null;
}
</script>

<%- include('../partials/footer') %>
